#!/usr/bin/env bash
# cdp-launch — connect-or-launch a Chromium CDP browser.
# If a browser is already listening on the port, prints its URL and exits.
# Otherwise finds a binary, launches headless, waits for readiness, prints URL.
#
# Usage:
#   cdp-launch                          # default :9222, headless
#   cdp-launch --port 9333             # specific port
#   cdp-launch --headed                 # show the window
#   cdp-launch --browser /usr/bin/chromium  # explicit binary
#   cdp-launch --profile /tmp/my-profile    # custom user-data-dir
#   cdp-launch --timeout 15             # seconds to wait for readiness (default 10)
#   cdp-launch --no-sandbox              # add --no-sandbox for restricted environments
#
# Output: the CDP WebSocket URL on stdout (e.g. http://127.0.0.1:9222)
# Exit: 0 if ready, 1 if failed

set -euo pipefail

PORT=9222
HEADED=false
NO_SANDBOX=false
BROWSER=""
PROFILE=""
TIMEOUT=10
HOST="127.0.0.1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port)     PORT="$2"; shift 2 ;;
    --headed)   HEADED=true; shift ;;
    --browser)  BROWSER="$2"; shift 2 ;;
    --profile)  PROFILE="$2"; shift 2 ;;
    --timeout)  TIMEOUT="$2"; shift 2 ;;
    --no-sandbox) NO_SANDBOX=true; shift ;;
    -h|--help)  sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)          echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

cdp_url="http://${HOST}:${PORT}"

# --- Ensure playwright-core is installed ---
if [ ! -d /tmp/playwright-cdp/node_modules/playwright-core ]; then
  echo "Installing playwright-core..." >&2
  mkdir -p /tmp/playwright-cdp
  cd /tmp/playwright-cdp
  npm init -y --silent >/dev/null 2>&1
  npm install playwright-core --silent 2>&1 >&2
fi

echo "Project ready: /tmp/playwright-cdp" >&2

# --- Already running? Connect and exit ---
if version_info=$(curl -sf "${cdp_url}/json/version" 2>&1); then
  echo "Browser ready: ${cdp_url} (already running)"
  echo "$version_info"
  exit 0
fi

# --- Find browser binary ---
if [[ -z "$BROWSER" ]]; then
  BROWSER=$(command -v google-chrome 2>/dev/null \
    || command -v chromium-browser 2>/dev/null \
    || command -v chromium 2>/dev/null \
    || command -v google-chrome-stable 2>/dev/null \
    || true)
  # macOS fallback
  if [[ -z "$BROWSER" && "$(uname)" == "Darwin" ]]; then
    mac_chrome="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    [[ -x "$mac_chrome" ]] && BROWSER="$mac_chrome"
  fi
fi

if [[ -z "$BROWSER" ]]; then
  echo "Error: no Chromium binary found. Install Chrome/Chromium or pass --browser." >&2
  exit 1
fi

echo "Launching ${BROWSER}..." >&2

# --- Launch ---
headless_flag="--headless"
[[ "$HEADED" == true ]] && headless_flag=""

sandbox_flag=""
[[ "$NO_SANDBOX" == true ]] && sandbox_flag="--no-sandbox"

if [[ -z "$PROFILE" ]]; then
  PROFILE="/tmp/chrome-cdp-profile-${PORT}"
fi
mkdir -p "$PROFILE"

"$BROWSER" \
  $headless_flag \
  $sandbox_flag \
  --remote-debugging-port="$PORT" \
  --user-data-dir="$PROFILE" \
  --no-first-run \
  --no-default-browser-check \
  &>/dev/null &

# --- Wait for readiness ---
elapsed=0
while [[ $elapsed -lt $TIMEOUT ]]; do
  if version_info=$(curl -sf "${cdp_url}/json/version" 2>&1); then
    echo "Browser ready: ${cdp_url} (${BROWSER})"
    echo "$version_info"
    exit 0
  fi
  sleep 1
  ((elapsed++)) || true
done

echo "Error: browser did not become ready on ${cdp_url} within ${TIMEOUT}s" >&2
exit 1